{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Companion Platform",
  "version": "0.1.0",
  "identifier": "com.sidekickreborn.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Companion Platform",
        "width": 1200,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/runtime-sidecar"
    ],
    "targets": "all"
  }
}
